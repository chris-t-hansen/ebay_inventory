# ==============================================================================
# ebay_inventory Environment Variables Template
# Copy this file to '.env' and fill in your details. Never commit '.env' to git!
# ==============================================================================

# 1. MariaDB Database Connection Parameters
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=ebay_user
DB_PASSWORD=your_secure_password
DB_NAME=ebay_inventory

# 2. eBay Developer Application Keys (https://developer.ebay.com)
# Standard keys obtained from your developer account dashboard
EBAY_APP_ID=your_ebay_production_or_sandbox_appid   # Also known as Client ID
EBAY_DEV_ID=your_ebay_developer_devid               # Developer program identifier
EBAY_CERT_ID=your_ebay_production_or_sandbox_certid # Also known as Client Secret
EBAY_REDIRECT_URI=your_configured_ruName            # eBay RuName (Redirect URI Name)

# 3. eBay Environment Selection
# Set to 'sandbox' for testing or 'production' for live operation
EBAY_ENVIRONMENT=sandbox

# 4. Auth Tokens (will be written and auto-refreshed by the Python application)
EBAY_ACCESS_TOKEN=
EBAY_REFRESH_TOKEN=
